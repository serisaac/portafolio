---
const socials = [
  { label: 'GitHub', href: 'https://github.com/' },
  { label: 'GitLab', href: 'https://gitlab.com/' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/sergio-isaac-moreno-alvarez-470765244/' },
];
---

<section class="section contact" id="contact">
  <div class="section__head">
    <p class="section__label">Contacto</p>
    <h2>Si tienes una idea pequeña o un reto más serio, puedo ayudarte a convertirlo en una web clara.</h2>
  </div>

  <div class="contact__layout">
    <form class="contact__form" action="https://formspree.io/f/xnjkdllp" method="post" novalidate>
      <label>
        <span>Nombre</span>
        <input name="name" type="text" autocomplete="name" required minlength="2" placeholder="Tu nombre" />
      </label>

      <label>
        <span>Email</span>
        <input name="email" type="email" autocomplete="email" required placeholder="tu@email.com" />
      </label>

      <label>
        <span>Mensaje</span>
        <textarea name="message" rows="6" minlength="10" required placeholder="Cuéntame un poco de tu proyecto"></textarea>
      </label>

      <button class="button button--primary" type="submit">Enviar mensaje</button>
      <p class="contact__status" aria-live="polite" role="status"></p>
    </form>

    <aside class="contact__panel">
      <div class="contact__card">
        <h3>Contacto directo</h3>
        <a href="mailto:serisaac11@gmail.com">serisaac11@gmail.com</a>
      </div>

      <div class="contact__card">
        <h3>Redes</h3>
        <ul>
          {socials.map((social) => (
            <li><a href={social.href} target="_blank" rel="noreferrer">{social.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="contact__card contact__card--availability">
        <span class="contact__dot" aria-hidden="true"></span>
        <div>
          <h3>Disponibilidad</h3>
          <p>Abierto a prácticas, colaboraciones pequeñas y trabajos de entrada.</p>
        </div>
      </div>
    </aside>
  </div>
</section>

<script>
  const form = document.querySelector('.contact__form');
  const status = document.querySelector('.contact__status');

  if (form && status) {
    const setStatus = (message, tone = 'neutral') => {
      status.textContent = message;
      status.dataset.tone = tone;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const name = String(formData.get('name') || '').trim();
      const email = String(formData.get('email') || '').trim();
      const message = String(formData.get('message') || '').trim();

      if (name.length < 2) {
        setStatus('Escribe un nombre válido.', 'error');
        form.querySelector('[name="name"]')?.focus();
        return;
      }

      if (!email || !form.querySelector('[name="email"]')?.checkValidity()) {
        setStatus('Necesito un email válido para responderte.', 'error');
        form.querySelector('[name="email"]')?.focus();
        return;
      }

      if (message.length < 10) {
        setStatus('El mensaje debe tener al menos 10 caracteres.', 'error');
        form.querySelector('[name="message"]')?.focus();
        return;
      }

      const submitButton = form.querySelector('button[type="submit"]');
      const previousLabel = submitButton?.textContent;
      submitButton.disabled = true;
      submitButton.textContent = 'Enviando...';
      setStatus('Enviando mensaje…', 'loading');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) {
          throw new Error('request failed');
        }

        form.reset();
        setStatus('Mensaje enviado con éxito. Te responderé pronto.', 'success');
      } catch {
        setStatus('No se pudo enviar ahora. Intenta de nuevo en unos minutos.', 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = previousLabel || 'Enviar mensaje';
      }
    });
  }
</script>

<style>
  .section {
    max-width: 1160px;
    margin: 0 auto;
    padding: 4rem clamp(1rem, 3vw, 2rem) 5rem;
  }

  .section__head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .section__label {
    margin: 0;
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    max-width: 22ch;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .contact__layout {
    display: grid;
    gap: 1rem;
  }

  .contact__form,
  .contact__panel > * {
    border: 1px solid var(--border);
    border-radius: 1.3rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 92%, transparent), color-mix(in srgb, var(--espresso) 82%, transparent));
    box-shadow: var(--shadow);
  }

  .contact__form {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
  }

  label span,
  .contact__card h3 {
    font-weight: 700;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.95rem;
    background: color-mix(in srgb, var(--espresso) 70%, var(--roast));
    color: var(--cream);
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--muted);
  }

  input:focus,
  textarea:focus {
    border-color: var(--caramel);
    outline: none;
  }

  .contact__status {
    min-height: 1.5rem;
    margin: 0;
    color: var(--muted);
  }

  .contact__status[data-tone='success'] {
    color: #8fe4b0;
  }

  .contact__status[data-tone='error'] {
    color: #ffb1a3;
  }

  .contact__status[data-tone='loading'] {
    color: var(--foam);
  }

  .contact__panel {
    display: grid;
    gap: 1rem;
  }

  .contact__card {
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 1.3rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 92%, transparent), color-mix(in srgb, var(--espresso) 82%, transparent));
    box-shadow: var(--shadow);
  }

  .contact__card a {
    color: var(--foam);
  }

  .contact__card ul {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact__card p {
    margin: 0.35rem 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .contact__card--availability {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .contact__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: #4ade80;
    margin-top: 0.35rem;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
    animation: pulse 1.8s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.45);
    }

    70% {
      box-shadow: 0 0 0 0.55rem rgba(74, 222, 128, 0);
    }
  }

  @media (min-width: 800px) {
    .contact__layout {
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    }
  }
</style>
