---
const phrases = ['desarrollador frontend', 'pensando en productos reales', 'enfocado en resultados', 'listo para aportar'];
const codeSnippet = String.raw`const portfolio = {
  stack: 'Astro + React',
  style: 'cappuccino',
  focus: ['UI', 'rendimiento', 'empleo']
};`;
---

<section class="hero" id="top">
  <div class="hero__content">
    <p class="eyebrow">Sergio Isaac Moreno Alvarez · Frontend junior en búsqueda de su primera oportunidad</p>
    <h1>Escribo frontend con café real — el gato solo aporta actitud.</h1>
    <p class="hero__lede">
      Soy desarrollador frontend en formación con una base sólida en experiencia de usuario, rendimiento y diseño útil. Estoy preparado para aportar valor en equipos que valoren compromiso, criterio y ganas de crecer.
    </p>

    <div class="hero__highlights" aria-label="Áreas de enfoque">
      <span>Frontend</span>
      <span>UI & UX</span>
      <span>Astro</span>
      <span>Trabajo en equipo</span>
    </div>

    <div class="hero__meta" aria-label="Indicadores de valor">
      <span>Disponible para empleo</span>
      <span>Listo para aportar desde el primer día</span>
    </div>

    <div class="terminal" aria-label="Terminal animada">
      <div class="terminal__header">
        <span></span><span></span><span></span>
      </div>
      <div class="terminal__body">
        <p class="terminal__prompt">usuario@astro:~$</p>
        <p class="terminal__line" aria-live="polite">
          <span class="terminal__cursor">▍</span>
          <span class="terminal__phrase" data-phrases={JSON.stringify(phrases)}>desarrollador frontend</span>
        </p>
        <p class="terminal__hint">Estoy listo para aportar valor a productos reales.</p>
      </div>
    </div>

    <div class="hero__actions">
      <a class="button button--primary" href="#projects">Ver proyectos</a>
      <a class="button button--ghost" href="#contact">Hablemos</a>
    </div>
  </div>

  <div class="hero__aside">
    <article class="code-card" aria-label="Tarjeta de código flotante">
      <p class="code-card__title"><span class="code-card__dot"></span>Enfoque actual</p>
      <pre><code>{codeSnippet}</code></pre>
      <p class="code-card__footer">Diseño, ejecución y claridad de mensaje para productos digitales.</p>
    </article>

    <div class="scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <i></i>
    </div>
  </div>
</section>

<script>
  const phraseNode = document.querySelector('.terminal__phrase');
  if (phraseNode) {
    const phrases = JSON.parse(phraseNode.dataset.phrases || '[]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let index = 0;
    let charIndex = 0;
    let deleting = false;

    if (reduceMotion || !phrases.length) {
      phraseNode.textContent = phrases[0] || phraseNode.textContent;
    } else {
      const tick = () => {
        const current = phrases[index];
        const nextLength = deleting ? charIndex - 1 : charIndex + 1;
        charIndex = Math.max(0, Math.min(current.length, nextLength));
        phraseNode.textContent = current.slice(0, charIndex);

        if (!deleting && charIndex === current.length) {
          deleting = true;
          setTimeout(tick, 1100);
          return;
        }

        if (deleting && charIndex === 0) {
          deleting = false;
          index = (index + 1) % phrases.length;
        }

        const delay = deleting ? 45 : 70;
        setTimeout(tick, delay);
      };

      setTimeout(tick, 500);
    }
  }
</script>

<style>
  .hero {
    max-width: 1160px;
    margin: 0 auto;
    padding: 8.5rem clamp(1rem, 3vw, 2rem) 4rem;
    display: grid;
    gap: 2rem;
    min-height: 100svh;
    align-items: center;
  }

  .hero__content {
    position: relative;
    display: grid;
    gap: 1.35rem;
  }

  .hero__content::before {
    content: '';
    position: absolute;
    inset: -1rem auto auto -1rem;
    width: 7rem;
    height: 7rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--caramel) 24%, transparent) 0%, transparent 70%);
    filter: blur(18px);
    pointer-events: none;
    z-index: -1;
  }

  .eyebrow {
    margin: 0;
    width: fit-content;
    padding: 0.45rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--roast) 76%, transparent);
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 8vw, 6.4rem);
    line-height: 0.93;
    letter-spacing: -0.04em;
  }

  .hero__lede {
    max-width: 60ch;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
  }

  .hero__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero__highlights span {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--roast) 84%, transparent);
    color: var(--cream);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .hero__meta span {
    padding: 0.45rem 0.8rem;
    border: 1px solid color-mix(in srgb, var(--caramel) 28%, var(--border));
    border-radius: 999px;
    background: color-mix(in srgb, var(--caramel) 12%, var(--roast));
    color: var(--foam);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .terminal {
    width: min(100%, 34rem);
    border: 1px solid var(--border);
    border-radius: 1.35rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 92%, transparent), color-mix(in srgb, var(--espresso) 80%, transparent));
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .terminal__header {
    display: flex;
    gap: 0.5rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--espresso) 70%, transparent);
  }

  .terminal__header span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--foam) 60%, var(--border));
  }

  .terminal__body {
    padding: 1.1rem 1.1rem 1.2rem;
    display: grid;
    gap: 0.55rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .terminal__prompt,
  .terminal__hint {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .terminal__line {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    font-weight: 600;
    color: var(--cream);
    font-size: clamp(1rem, 2vw, 1.1rem);
  }

  .terminal__cursor {
    animation: blink 1s step-end infinite;
    color: var(--caramel);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    padding-top: 0.2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.1rem;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .button--primary {
    background: var(--caramel);
    color: var(--espresso);
    border-color: color-mix(in srgb, var(--caramel) 70%, white 10%);
  }

  .button--ghost {
    background: color-mix(in srgb, var(--roast) 78%, transparent);
    color: var(--cream);
  }

  .hero__aside {
    display: grid;
    gap: 1rem;
    justify-items: end;
  }

  .code-card {
    width: min(100%, 24rem);
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 1.4rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 94%, transparent), color-mix(in srgb, var(--espresso) 86%, transparent));
    box-shadow: var(--shadow);
    animation: float 7s ease-in-out infinite;
    transition: opacity 0.4s ease, transform 0.4s ease;

    @starting-style {
      opacity: 0;
      transform: translateY(16px);
    }
  }

  .code-card__title {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 0.8rem;
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .code-card__dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--caramel);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--caramel) 18%, transparent);
  }

  .code-card pre {
    margin: 0;
    overflow-x: auto;
    color: var(--cream);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .code-card__footer {
    margin: 0.7rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .scroll-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .scroll-indicator i {
    position: relative;
    width: 2.2rem;
    height: 3.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  .scroll-indicator i::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 0.6rem;
    width: 0.45rem;
    height: 0.8rem;
    border-radius: 999px;
    background: var(--caramel);
    transform: translateX(-50%);
    animation: scroll 1.8s ease-in-out infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @keyframes float {
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes scroll {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.55;
    }

    50% {
      transform: translateX(-50%) translateY(1.45rem);
      opacity: 1;
    }
  }

  @media (min-width: 800px) {
    .hero {
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      gap: 2.5rem;
    }

    .hero__content {
      padding-right: 1rem;
    }
  }
</style>
