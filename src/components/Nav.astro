---
const links = [
  { href: '#about', label: 'Sobre mí' },
  { href: '#experience', label: 'Experiencia' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#skills', label: 'Habilidades' },
  { href: '#contact', label: 'Contacto' },
];
---

<nav class="nav" id="site-nav" aria-label="Principal">
  <div class="nav__inner">
    <a class="brand" href="#top" aria-label="Ir al inicio">
      <span class="brand__mark">&lt;/&gt;</span>
      <span class="brand__name">sergio isaac</span>
    </a>

    <button class="nav__toggle" type="button" aria-expanded="false" aria-controls="nav-links">
      <span class="nav__toggle-bars" aria-hidden="true"></span>
      <span class="sr-only">Abrir menú</span>
    </button>

    <div class="nav__links" id="nav-links">
      {links.map((link) => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector('#site-nav');
  const toggle = nav?.querySelector('.nav__toggle');
  const links = nav?.querySelectorAll('.nav__link');

  if (nav && toggle) {
    const setOpen = (open) => {
      nav.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    };

    toggle.addEventListener('click', () => setOpen(nav.dataset.open !== 'true'));
    links?.forEach((link) => link.addEventListener('click', () => setOpen(false)));
    setOpen(false);
  }
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    padding: 1rem clamp(1rem, 3vw, 2rem);
    background: color-mix(in srgb, var(--espresso) 76%, transparent);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
  }

  .nav::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--foam) 70%, transparent), transparent);
    opacity: 0.5;
  }

  .nav__inner {
    max-width: 1160px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brand__mark {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--roast) 80%, transparent);
    color: var(--foam);
  }

  .brand__name {
    font-size: 0.95rem;
  }

  .nav__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--roast) 88%, transparent);
    color: var(--cream);
  }

  .nav__toggle-bars {
    position: relative;
    width: 1.1rem;
    height: 1px;
    background: currentColor;
    border-radius: 999px;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .nav__toggle-bars::before,
  .nav__toggle-bars::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    height: 1px;
    background: currentColor;
    border-radius: inherit;
    transition: transform 0.25s ease, top 0.25s ease, bottom 0.25s ease;
  }

  .nav__toggle-bars::before {
    top: -0.35rem;
  }

  .nav__toggle-bars::after {
    bottom: -0.35rem;
  }

  .nav__links {
    position: absolute;
    inset: calc(100% + 0.75rem) 1rem auto;
    display: grid;
    gap: 0.5rem;
    padding: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--roast) 94%, transparent);
    box-shadow: var(--shadow);
    opacity: 0;
    transform: translateY(-0.35rem) scale(0.98);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;

    @starting-style {
      opacity: 0;
      transform: translateY(-0.75rem) scale(0.98);
    }
  }

  .nav[data-open='true'] .nav__links {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .nav[data-open='true'] .nav__toggle-bars {
    background: transparent;
  }

  .nav[data-open='true'] .nav__toggle-bars::before {
    top: 0;
    transform: rotate(45deg);
  }

  .nav[data-open='true'] .nav__toggle-bars::after {
    bottom: 0;
    transform: rotate(-45deg);
  }

  .nav__link {
    position: relative;
    padding: 0.7rem 0.85rem;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.4rem;
    height: 1px;
    background: linear-gradient(90deg, var(--caramel), var(--foam));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav__link:hover::after,
  .nav__link:focus-visible::after {
    transform: scaleX(1);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 800px) {
    .nav__toggle {
      display: none;
    }

    .nav__links {
      position: static;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    .nav__link {
      padding-inline: 1rem;
    }
  }
</style>
