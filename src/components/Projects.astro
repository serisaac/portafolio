---
const projects = [
  {
    number: '01',
    title: 'Landing de cafetería',
    description: 'Sitio promocional responsive con foco en jerarquía visual, CTA claros y carga rápida.',
    accent: '#C8874A',
    tags: ['Astro', 'UI', 'Responsive'],
    github: 'https://github.com/',
    demo: '#',
  },
  {
    number: '02',
    title: 'Panel de estudio',
    description: 'Dashboard simple para organizar hábitos de aprendizaje y revisar progreso semanal.',
    accent: '#E8C99A',
    tags: ['JavaScript', 'Dashboard', 'UX'],
    github: 'https://github.com/',
    demo: '#',
  },
  {
    number: '03',
    title: 'Portfolio minimal',
    description: 'Portfolio personal con navegación fluida, secciones cortas y animaciones discretas.',
    accent: '#B06F3E',
    tags: ['Astro', 'A11y', 'Motion'],
    github: 'https://github.com/',
    demo: '#',
  },
  {
    number: '04',
    title: 'Landing de producto',
    description: 'Página de presentación pensada para convertir con una narrativa visual más editorial.',
    accent: '#D8A264',
    tags: ['Design', 'Copy', 'Landing'],
    github: 'https://github.com/',
    demo: '#',
  },
];
---

<section class="section projects" id="projects">
  <div class="section__head">
    <p class="section__label">Proyectos</p>
    <h2>Cuatro piezas de práctica que muestran proceso, criterio y atención al detalle.</h2>
  </div>

  <div class="projects__grid">
    {projects.map((project) => (
      <article class="project-card" style={`--accent:${project.accent}`}>
        <span class="project-card__bar" aria-hidden="true"></span>
        <p class="project-card__number">{project.number}</p>
        <h3>{project.title}</h3>
        <p>{project.description}</p>

        <ul class="project-card__tags" aria-label={`Etiquetas de ${project.title}`}>
          {project.tags.map((tag) => <li>{tag}</li>)}
        </ul>

        <div class="project-card__links">
          <a href={project.github} target="_blank" rel="noreferrer" aria-label={`Abrir GitHub de ${project.title}`}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .6C5.6.6.4 5.8.4 12.2c0 5.1 3.3 9.4 7.9 11-.1-.8-.1-2 0-2.9.1-.8 0-1.3 0-1.3-3.2.6-3.9-1.4-3.9-1.4-.5-1.4-1.3-1.8-1.3-1.8-1.1-.8.1-.8.1-.8 1.3.1 2 1.4 2 1.4 1.1 2 2.8 1.4 3.4 1 .1-.8.4-1.4.8-1.7-2.5-.3-5.1-1.3-5.1-5.9 0-1.3.4-2.4 1.2-3.3-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.4 1.3 1-.3 2.1-.5 3.2-.5s2.2.2 3.2.5c2.4-1.6 3.4-1.3 3.4-1.3.6 1.6.2 2.8.1 3.1.8.9 1.2 2 1.2 3.3 0 4.6-2.6 5.6-5.1 5.9.4.4.8 1.1.8 2.2 0 1.6 0 2.9 0 3.3 4.6-1.6 7.9-5.9 7.9-11 0-6.4-5.2-11.6-11.6-11.6z" fill="currentColor"/></svg>
            GitHub
          </a>
          <a href={project.demo} aria-label={`Abrir demo de ${project.title}`}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3h7v7h-2V6.4l-9.3 9.3-1.4-1.4L17.6 5H14V3zM5 5h6V3H3v8h2V5zm14 14h-6v2h8v-8h-2v6zM5 19v-6H3v8h8v-2H5z" fill="currentColor"/></svg>
            Demo
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: 1160px;
    margin: 0 auto;
    padding: 4rem clamp(1rem, 3vw, 2rem);
  }

  .section__head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .section__label {
    margin: 0;
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    max-width: 22ch;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .projects__grid {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 1.3rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 92%, transparent), color-mix(in srgb, var(--espresso) 82%, transparent));
    box-shadow: var(--shadow);
  }

  .project-card__bar {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 0.25rem;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .project-card:hover .project-card__bar,
  .project-card:focus-within .project-card__bar {
    transform: scaleX(1);
  }

  .project-card__number {
    margin: 0 0 0.75rem;
    color: color-mix(in srgb, var(--accent) 80%, var(--cream));
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.16em;
  }

  .project-card h3 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.3rem, 3vw, 1.75rem);
  }

  .project-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 1.1rem;
    padding: 0;
    list-style: none;
  }

  .project-card__tags li {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    background: color-mix(in srgb, var(--accent) 15%, var(--roast));
    color: color-mix(in srgb, var(--accent) 72%, var(--cream));
    font-size: 0.82rem;
    font-weight: 600;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project-card__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--cream);
    font-weight: 700;
  }

  .project-card__links svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  @media (min-width: 800px) {
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
