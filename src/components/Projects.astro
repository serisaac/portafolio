---
const projects = [
  {
    number: '01',
    title: 'Cafetería Isa',
    role: 'UI + E-commerce',
    challenge: 'Conectar el catálogo a una base de datos real fue la parte que más tiempo me tomó: los productos no siempre llegaban como esperaba y tuve que ajustar cómo se guardaban y mostraban hasta que la carta se viera consistente. Sumar un mapa de ubicación (sin llegar a tiempo real) también implicó decidir cuánto detalle valía la pena mostrar.',
    designChoice: 'La paleta cálida y un diseño más parecido a un menú físico que a una tienda genérica fue decisión mía: quería que se sintiera como entrar a una cafetería, no a un checkout.',
    accent: '#C8874A',
    tags: ['React', 'UI', 'E-commerce'],
    stack: 'React · Vercel',
    github: 'https://github.com/serisaac/cafeteria-isa',
    demo: 'https://cafeteria-isa-hohm.vercel.app/',
    highlight: 'Experiencia de compra digital para negocio local',
  },
  {
    number: '02',
    title: 'Portafolio Charly',
    role: 'Portfolio profesional',
    challenge: 'Aquí el reto fue más de traducción que de código: le pedí a Charly su información y fui armando secciones a partir de lo que me compartía, en vez de partir de una plantilla ya definida.',
    designChoice: 'El estilo visual salió de su perfil profesional, no de un template — ajusté tono y jerarquía para que un reclutador entienda quién es él en los primeros segundos.',
    accent: '#E8C99A',
    tags: ['React', 'Tailwind', 'Branding'],
    stack: 'React · Tailwind',
    github: 'https://github.com/serisaac/portafolioCharly',
    demo: 'https://portafolio-charly.vercel.app/',
    highlight: 'Diseño personal alineado a imagen profesional',
  },
  {
    number: '03',
    title: 'Panadería Milagro',
    role: 'Landing de producto',
    challenge: 'Como en Cafetería Isa, conectar productos a la base de datos y sumar el mapa de ubicación fue lo que más ajustes pidió — hubo momentos donde el diseño y los datos no cuadraban y tuve que revisar ambos lados.',
    designChoice: 'Elegí una identidad más artesanal que la de la cafetería, pensando en que una panadería local transmite algo distinto: más calidez de barrio que de negocio digital.',
    accent: '#B06F3E',
    tags: ['UI', 'E-commerce', 'Copy'],
    stack: 'React · Vercel',
    github: 'https://github.com/serisaac/panaderia-milagro',
    demo: 'https://panaderia-milagro.vercel.app/',
    highlight: 'Identidad visual para marca local',
  },
];
---

<section class="section projects" id="projects">
  <div class="section__head">
    <p class="section__label">Proyectos</p>
    <h2>Tres proyectos que muestran mi proceso, criterio y enfoque por crear experiencias claras y memorables.</h2>
  </div>

  <div class="projects__grid">
    {projects.map((project) => (
      <article class="project-card" style={`--accent:${project.accent}`}>
        <div class="project-card__bar"></div>
        <div class="project-card__header">
          <div>
            <p class="project-card__number">{project.number}</p>
            <h3>{project.title}</h3>
          </div>
          <span class="project-card__pill">{project.role}</span>
        </div>

        <p class="project-card__highlight">{project.highlight}</p>
        <p><strong>Desafío:</strong> {project.challenge}</p>
        <p><strong>Decisión de diseño:</strong> {project.designChoice}</p>

        <div class="project-card__meta">
          <ul class="project-card__tags" aria-label={`Etiquetas de ${project.title}`}>
            {project.tags.map((tag) => <li>{tag}</li>)}
          </ul>
          <span class="project-card__stack">{project.stack}</span>
        </div>

        <div class="project-card__links">
          <a href={project.demo} aria-label={`Abrir demo de ${project.title}`}>
            Ver demo
          </a>
          <a href={project.github} target="_blank" rel="noreferrer" aria-label={`Abrir GitHub de ${project.title}`}>
            Código
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .section {
    max-width: 1160px;
    margin: 0 auto;
    padding: 4rem clamp(1rem, 3vw, 2rem);
  }

  .section__head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .section__label {
    margin: 0;
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    max-width: 22ch;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .projects__grid {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 1.3rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--roast) 92%, transparent), color-mix(in srgb, var(--espresso) 82%, transparent));
    box-shadow: var(--shadow);
  }

  .project-card__bar {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 0.25rem;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .project-card:hover .project-card__bar,
  .project-card:focus-within .project-card__bar {
    transform: scaleX(1);
  }

  .project-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(-3px);
    box-shadow: 0 35px 80px rgba(11, 6, 3, 0.18);
  }

  .project-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, color-mix(in srgb, var(--accent) 10%, transparent) 45%, transparent 100%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .project-card:hover::after,
  .project-card:focus-within::after {
    opacity: 1;
  }

  .project-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .project-card__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 14%, var(--roast));
    color: color-mix(in srgb, var(--accent) 72%, var(--cream));
    font-size: 0.78rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .project-card__number {
    margin: 0 0 0.75rem;
    color: color-mix(in srgb, var(--accent) 80%, var(--cream));
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.16em;
  }

  .project-card h3 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.3rem, 3vw, 1.75rem);
  }

  .project-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .project-card__highlight {
    margin-bottom: 0.35rem !important;
    color: color-mix(in srgb, var(--accent) 78%, var(--cream)) !important;
    font-weight: 700;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 1.1rem;
    padding: 0;
    list-style: none;
  }

  .project-card__tags li {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    background: color-mix(in srgb, var(--accent) 15%, var(--roast));
    color: color-mix(in srgb, var(--accent) 72%, var(--cream));
    font-size: 0.82rem;
    font-weight: 600;
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 1rem 0 0.9rem;
  }

  .project-card__stack {
    color: var(--foam);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project-card__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    min-width: 10rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: color-mix(in srgb, var(--accent) 30%, var(--roast));
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
  }

  .project-card__links a:hover,
  .project-card__links a:focus-visible {
    transform: translateY(-1px);
    background: var(--accent);
    border-color: var(--accent);
    color: var(--espresso);
  }

  @media (min-width: 800px) {
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
