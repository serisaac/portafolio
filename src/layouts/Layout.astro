---
import { ViewTransitions } from 'astro:transitions';

const { title = 'Sergio Isaac Moreno Alvarez | Desarrollador Frontend', description = 'Portafolio profesional de Sergio Isaac Moreno Alvarez, desarrollador frontend en formación listo para aportar en proyectos reales y oportunidades laborales.' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1C1410" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --espresso: #1C1410;
    --roast: #2C1F14;
    --caramel: #C8874A;
    --cream: #F2E4D0;
    --foam: #E8C99A;
    --muted: #8C7B6B;
    --border: #3D2E22;
    --shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    color-scheme: dark;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--caramel) 18%, transparent), transparent 30%),
      radial-gradient(circle at top right, color-mix(in srgb, var(--foam) 10%, transparent), transparent 24%),
      var(--espresso);
  }

  body {
    position: relative;
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 20% 10%, rgba(200, 135, 74, 0.12), transparent 26%),
      radial-gradient(circle at 80% 0%, rgba(232, 201, 154, 0.08), transparent 24%),
      linear-gradient(180deg, #201611 0%, #1C1410 35%, #18110d 100%);
    color: var(--cream);
    font-family: 'Inter', system-ui, sans-serif;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body::before,
  body::after {
    content: '';
    position: fixed;
    inset: auto;
    pointer-events: none;
    z-index: -1;
    filter: blur(38px);
    opacity: 0.35;
  }

  body::before {
    top: -2rem;
    left: -3rem;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 135, 74, 0.4), transparent 70%);
  }

  body::after {
    right: -3rem;
    top: 8rem;
    width: 16rem;
    height: 16rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 201, 154, 0.24), transparent 70%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea {
    font: inherit;
  }

  img {
    max-width: 100%;
    display: block;
  }

  ::selection {
    background: color-mix(in srgb, var(--caramel) 60%, white 12%);
    color: var(--espresso);
  }

  :focus-visible {
    outline: 2px solid var(--caramel);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
